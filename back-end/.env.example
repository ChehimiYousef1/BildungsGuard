# --- Core ---
PORT=3000
# Runtime connection — non-superuser, subject to Row-Level Security
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/allinone?schema=public"
# Privileged connection — used by prisma migrate & seed (superuser bypasses RLS)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/allinone?schema=public"

# --- Auth (CHANGE THESE IN PRODUCTION) ---
JWT_SECRET="change-me-access"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Redis (Bull jobs) ---
REDIS_HOST="localhost"
REDIS_PORT=6379

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="all-in-one"

# --- SMTP (email) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@all-in-one.de"

# --- Anthropic (Aino assistant) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
